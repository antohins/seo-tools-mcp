# Конфиг: ~/.config/seo-tools-mcp/.env (chmod 600) — все серверы читают его автоматически.
# Заполнять руками НЕ обязательно: у каждого сервера есть инструменты
# <server>_auth_status / <server>_set_credentials — ключи можно передать прямо в чате,
# они сохранятся сюда сами. Значения НИКОГДА не коммитить.
#
# МУЛЬТИАККАУНТ: любой ключ можно продублировать с суффиксом __<имя-профиля>
# (например GSC_REFRESH_TOKEN__client1, YANDEX_OAUTH_TOKEN__client1) — инструменты
# принимают параметр account. OAuth-приложения (GOOGLE_CLIENT_*, YANDEX_CLIENT_*)
# общие для всех профилей.

# ── xmlstock (SERP Google+Яндекс) — https://xmlstock.com → личный кабинет ──
XMLSTOCK_USER=
XMLSTOCK_KEY=
# домены-агрегаторы для флага excludeAggregators (опционально, есть дефолт)
#XMLSTOCK_EXCLUDE_DOMAINS=avito.ru,cian.ru
# цена за запрос для счётчика расхода в stderr (₽; опционально, дефолт 0.02)
#XMLSTOCK_PRICE_PER_CALL=0.02

# ── wordstat (официальный Wordstat API v2, Yandex Cloud) — БЕСПЛАТНЫЙ ──
# console.yandex.cloud: каталог → сервисный аккаунт (роль search-api.webSearch.user)
# → API-ключ (scope yc.search-api.execute). Квоты: 10 rps, 100 запросов/час.
WORDSTAT_API_KEY=
WORDSTAT_FOLDER_ID=

# ── Google Search Console — два пути (приоритет у OAuth) ──
# Путь A (рекомендуемый): OAuth — токен видит ВСЕ свойства аккаунта.
# OAuth client (Desktop app) из console.cloud.google.com; токены — через gsc_oauth_start/finish.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GSC_REFRESH_TOKEN=
# Путь B: сервис-аккаунт (для кронов) — добавлять его email в каждое свойство.
GSC_SA_JSON=
# Свойство по умолчанию (иначе передавать siteUrl в каждом вызове)
GSC_SITE_URL=
# порт loopback-приёмника кода OAuth (опционально, дефолт 8585)
#GSC_OAUTH_PORT=8585

# ── Яндекс (Вебмастер + Метрика) — общее OAuth-приложение ──
# Интерактивно: ywm_oauth_start / metrika_oauth_start → ссылка → код → *_oauth_finish.
# Токен и refresh сохраняются сюда автоматически, обновление — тоже автоматическое.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_OAUTH_TOKEN=
YANDEX_REFRESH_TOKEN=
# Отдельные токены (перекрывают общий; обычно не нужны):
#YWM_OAUTH_TOKEN=
#METRIKA_OAUTH_TOKEN=

# ── Дефолты Вебмастера (иначе передавать в вызовах; список — ywm_hosts) ──
YWM_HOST_ID=
#YWM_USER_ID=

# ── Дефолты Метрики (список счётчиков — metrika_counters) ──
METRIKA_COUNTER_ID=
