{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.antohins/seo-tools-mcp-metrika",
  "title": "SEO Tools: Yandex.Metrica",
  "description": "MCP server for Yandex.Metrica Stat API (read-only).",
  "repository": {
    "url": "https://github.com/antohins/seo-tools-mcp",
    "source": "github"
  },
  "websiteUrl": "https://github.com/antohins/seo-tools-mcp#readme",
  "version": "1.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "seo-tools-mcp-metrika",
      "version": "1.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "YANDEX_OAUTH_TOKEN",
          "description": "Yandex OAuth token (shared Webmaster + Metrica); or obtain via metrika_oauth_start.",
          "format": "string",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "METRIKA_COUNTER_ID",
          "description": "Default Yandex.Metrica counter ID.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}
