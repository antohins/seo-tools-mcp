{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.antohins/seo-tools-mcp-xmlstock",
  "title": "SEO Tools: XMLStock SERP (Google + Yandex)",
  "description": "MCP server for Google & Yandex SERP via XMLStock (read-only).",
  "repository": {
    "url": "https://github.com/antohins/seo-tools-mcp",
    "source": "github"
  },
  "websiteUrl": "https://github.com/antohins/seo-tools-mcp#readme",
  "version": "1.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "seo-tools-mcp-xmlstock",
      "version": "1.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "XMLSTOCK_USER",
          "description": "XMLStock user ID (from the xmlstock.com dashboard).",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "XMLSTOCK_KEY",
          "description": "XMLStock API key.",
          "format": "string",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ]
}
